# ── Public demo (Streamlit Cloud) ───────────────────────────────────────────
# DEMO_MODE caps every AI-calling feature at a tiny lifetime budget (see
# core/demo_limit.py) so a public deployment can't run up your API bill.
# Leave unset for local/full use. DEMO_OWNER_KEY lets you unlock unlimited
# calls for your own browser session via the sidebar "Owner unlock" expander.
DEMO_MODE=
DEMO_OWNER_KEY=

ANTHROPIC_API_KEY=your_anthropic_api_key_here
FRED_API_KEY=your_fred_api_key_here
NEWSAPI_KEY=your_newsapi_key_here

# ── Data Provider ─────────────────────────────────────────────────────────────
# DATA_PROVIDER controls which source is used for OHLCV data.
# Options: yfinance (free, 60-day intraday limit) | eodhd (paid, full history)
DATA_PROVIDER=yfinance
EODHD_API_KEY=your_eodhd_api_key_here

# ── P4 Live Alerts ────────────────────────────────────────────────────────────
# Telegram (recommended) — create a bot via @BotFather, then message it to get your chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (Gmail example — use an App Password, not your main password)
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
ALERT_EMAIL_PASSWORD=
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
